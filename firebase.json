{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".*/**",
      "**/.DS_Store",
      "**/node_modules/**",
      "**/src/**",
      "**/dist/**",
      "**/scratch/**",
      "**/repo-extras/**",
      "**/.agents/**",
      "**/*.md",
      "**/*.ts",
      "**/*.mjs",
      "**/*.json",
      "**/*.lock",
      "index.html",
      "studio.html",
      "test-export.html"
    ],
    "rewrites": [
      { "source": "/api/**", "destination": "/api" },
      { "source": "**", "destination": "/splash.html" }
    ]
  }
}
