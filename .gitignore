# ──────────────────────────────────────────────────
#  /motion — .gitignore (public release)
# ──────────────────────────────────────────────────

# ─── OS noise ───
.DS_Store
Thumbs.db

# ─── Dependencies ───
node_modules/

# ─── Build output ───
dist/

# ─── Environment / secrets ───
.env
.env.local
.env.*.local

# ─── AI agent / coding tool configs (personal) ───
.agents/
.claude/
.codex/
.opencode/
.mimocode/

# ─── Editor / IDE settings ───
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Firebase / hosting (project-specific) ───
.firebase/
.firebaserc
firebase.json
sitemap.xml

# ─── Personal documentation vault ───
brain/

# ─── Deployment scripts (project-specific) ───
scripts/

# ─── Studio exports (generated locally) ───
lumen-*.png
lumen-*.webm
lumen-*.gif

# ─── Large binaries / copyrighted ───
*.pdf
*.webm

# ─── Python bytecode ───
__pycache__/
*.pyc
*.pyo

# ─── Agent context files (personal) ───
CLAUDE.md
AGENTS.md
